<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ── Permissions ────────────────────────────────────────────────── -->

    <!-- Camera and microphone for recording -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Foreground service for background recording (required on API 28+) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />

    <!-- Wakelock to keep CPU alive during recording -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Wi-Fi Direct -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <!-- ACCESS_FINE_LOCATION is required for Wi-Fi Direct on API 26–32 -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <!--
        NEARBY_WIFI_DEVICES was introduced in API 33 (Android 13) and replaces the
        coarse location requirement for Wi-Fi Direct peer discovery.
        On API 26-32, ACCESS_FINE_LOCATION above is used instead.
        The app checks Build.VERSION.SDK_INT >= Build.VERSION_CODES.TIRAMISU at runtime
        before requesting this permission.
    -->
    <uses-permission
        android:name="android.permission.NEARBY_WIFI_DEVICES"
        android:usesPermissionFlags="neverForLocation" />

    <!-- Bluetooth -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />

    <!-- Post notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Internet for Initiator upload -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- ── Hardware features (optional — don't block install) ─────────── -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.wifi.direct" android:required="false" />
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="false" />

    <application
        android:name=".MeshStreamApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MeshStream">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Recording foreground service -->
        <service
            android:name="com.meshstream.recorder.RecordingForegroundService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="camera|microphone" />

    </application>

</manifest>
